# ─────────────────────────────────────────────────────────────────────────────
# SkyRH showcase — config nginx (static export Next.js servi sous /showcase/).
#
# ⚠️ Cet hôte est nginx : public/.htaccess (Apache) est TOTALEMENT IGNORÉ. Cette
#    config porte ce que le .htaccess visait — cache HTML + en-têtes de sécurité —
#    et corrige le cache proxy qui servait un gateway /showcase/ OBSOLÈTE après un
#    déploiement (l'URL nue /showcase/ redirigeait vers l'ancienne cible → 404).
#
# Appliquer côté serveur/hébergeur (accès config nginx requis). Après application :
# recharger nginx (`nginx -s reload`) ET purger une fois l'entrée déjà en cache
# pour /showcase/ (le no-cache empêche les futures, pas celle déjà stockée).
#
# Si tu n'as pas la main sur nginx (mutualisé) : demander à l'hébergeur (a) de
# purger le cache et (b) de ne pas cacher les *.html de ce vhost.
# ─────────────────────────────────────────────────────────────────────────────

# 1) Au niveau http{} : Cache-Control selon le type de fichier. Un seul add_header
#    (variable) évite le piège nginx « un add_header dans un location enfant annule
#    ceux du parent » — tout reste dans le location /showcase/ ci-dessous.
map $uri $skyrh_cache {
    # HTML (dont le gateway /showcase/index.html) + RSC + répertoires : JAMAIS cachés.
    default                                              "no-cache, no-store, must-revalidate";
    # Assets immuables content-hashés (Next /_next/static + images) : cache agressif.
    "~*\.(?:js|css|woff2?|png|jpe?g|gif|svg|ico|webp)$"  "public, max-age=31536000, immutable";
}

# 2) Dans le server{} du vhost (rh.ikwhat.com). Adapter `root` au chemin réel
#    (le docroot où rsync dépose out/, ex. .../public_html/rh ; /showcase/ dessous).
location /showcase/ {
    try_files $uri $uri/ =404;

    # Pages inexistantes → la 404 stylée de Next (out/404.html, générée au build), pas le 404
    # brut d'nginx. nginx conserve le statut 404 en servant ce fichier statique.
    error_page 404 /showcase/404.html;
    # 403 / 5xx → même page stylée plutôt que la page d'erreur brute d'nginx.
    error_page 403 500 502 503 504 /showcase/404.html;

    # ⚠️ STAGING UNIQUEMENT — à RETIRER en prod. REDONDANT depuis que le noindex est piloté par le
    # BUILD (SHOWCASE_ENV → balise <meta robots> des pages, cf. app/[lang]/layout.tsx) : le staging est
    # déjà noindex sans ce header. Gardé en défense-en-profondeur ; NE DOIT PAS figurer sur la config
    # nginx de prod (sinon la prod, pourtant buildée indexable, serait masquée par ce header).
    add_header X-Robots-Tag "noindex, nofollow" always;

    add_header Cache-Control $skyrh_cache always;

    # En-têtes de sécurité — repris tels quels de public/.htaccess (ignoré ici).
    add_header X-Content-Type-Options   "nosniff" always;
    add_header X-Frame-Options          "DENY" always;
    add_header Referrer-Policy          "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy       "camera=(), microphone=(), geolocation=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy   "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://challenges.cloudflare.com https://www.googletagmanager.com; connect-src 'self' https:; frame-src https://js.stripe.com https://challenges.cloudflare.com;" always;
}

# Note : la redirection racine /showcase/ → /showcase/<lang>/ est déjà assurée par le
# gateway JS de out/index.html (scripts/postbuild.mjs), qui marche sans mod_rewrite ni
# règle nginx. Rien à ajouter ici pour ça.
