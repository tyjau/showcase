# SkyRH showcase — static export (Next.js output:export), served by Apache.
# Next copies public/ into out/ at build, so this lands at the deployed docroot
# (same delivery pattern as harmony's public/.htaccess).
# ⚠️ Apache UNIQUEMENT — un hôte nginx IGNORE ce fichier ; y porter ces règles en config
#    serveur (cf. deploy/nginx-showcase.conf.example).

Options -Indexes

# Pages inexistantes / erreurs → la 404 stylée de Next (out/404.html) plutôt que la page brute
# d'Apache. __BASE_PATH__ substitué au postbuild (vide → racine en prod).
ErrorDocument 404 __BASE_PATH__/404.html
ErrorDocument 403 __BASE_PATH__/404.html
ErrorDocument 500 __BASE_PATH__/404.html

# Marque les requêtes servies depuis le HOST de staging (pour le noindex conditionnel plus bas) —
# empêche Google d'indexer le staging sans toucher la prod (même .htaccess livré aux deux).
<IfModule mod_setenvif.c>
  SetEnvIf Host "rh\.ikwhat\.com" SKYRH_STAGING
</IfModule>

# The app lives entirely under /<lang>/ (static export, no middleware), so the bare
# domain and a few legacy paths need redirecting at the HTTP layer. A generated
# out/index.html covers hosts without mod_rewrite; these rules are the clean 302s.
# __BASE_PATH__ is substituted at postbuild (scripts/postbuild.mjs) with the deploy
# sub-path (e.g. /showcase), so the redirects land under it, not the domain root.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Root → locale: prefer French when the browser asks for it, else the default (en).
  RewriteCond %{HTTP:Accept-Language} ^fr [NC]
  RewriteRule ^$ __BASE_PATH__/fr/ [R=302,L]
  RewriteRule ^$ __BASE_PATH__/en/ [R=302,L]
</IfModule>

<IfModule mod_headers.c>
  # Never cache the HTML so the latest content-hashed assets are always picked up…
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  # …but cache the immutable, content-hashed assets aggressively.
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|gif|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Security headers.
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # noindex — appliqué UNIQUEMENT sur le host de staging (cf. SetEnvIf plus haut), jamais en prod.
  Header set X-Robots-Tag "noindex, nofollow" env=SKYRH_STAGING

  # Content-Security-Policy.
  # NOTE: a Next static export inlines per-page RSC bootstrap scripts (self.__next_f.push)
  # that vary and can't be hashed/nonced without a server, so script-src keeps
  # 'unsafe-inline'. The other directives still harden meaningfully (clickjacking,
  # object/base/form, and restricted img/style/connect/frame). Stripe is allowed for
  # checkout; Cloudflare Turnstile (challenges.cloudflare.com) for the captcha widget
  # (script + iframe); connect-src allows the (deploy-configured) guardian API over https;
  # partner logos are arbitrary https images.
  Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://challenges.cloudflare.com; connect-src 'self' https:; frame-src https://js.stripe.com https://challenges.cloudflare.com;"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>
